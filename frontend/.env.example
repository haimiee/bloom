# Build-time API configuration for Vite.
# Copy this file to .env.local for local dev or .env.production for production builds.

# Landing hero art. Can be an absolute URL or a public folder asset path.
# Example: /landing-hero.png (file in frontend/public)
VITE_LANDING_HERO_IMAGE_URL=/landing-hero.png

# Optional full-page backgrounds. Use PNGs if you want to replace the default gradients.
VITE_LANDING_BACKGROUND_IMAGE_URL=
VITE_DASHBOARD_BACKGROUND_IMAGE_URL=

# Optional plant artwork. If provided, the CSS plant drawing is replaced per stage.
VITE_PLANT_IMAGE_URL=
VITE_PLANT_STAGE_0_IMAGE_URL=
VITE_PLANT_STAGE_1_IMAGE_URL=
VITE_PLANT_STAGE_2_IMAGE_URL=
VITE_PLANT_STAGE_3_IMAGE_URL=
VITE_PLANT_STAGE_4_IMAGE_URL=

# Option A: direct backend URL (different host or port)
# IMPORTANT: when frontend is opened from another computer/browser, do not use 127.0.0.1.
# Use your VM public IP or domain, for example:
# VITE_API_BASE_URL=http://172.233.163.115:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# Option B: if using reverse proxy and /api routing on same domain,
# set VITE_API_BASE_URL to your frontend origin and use /api endpoints below.
# VITE_API_BASE_URL=https://your-domain.com

# Endpoint paths (can also be full URLs if needed)
VITE_SIGNUP_ENDPOINT=/auth/signup
VITE_LOGIN_ENDPOINT=/auth/login
VITE_WATER_ENDPOINT=/water
